# Copia este archivo como .env y completa los valores vacíos localmente.
# Nunca versiones .env ni compartas sus valores.

DB_URL=jdbc:postgresql://localhost:5432/loans_db
DB_USERNAME=loans_user
DB_PASSWORD=

JWT_SECRET=
JWT_EXPIRATION=PT30M
CORS_ALLOWED_ORIGIN=http://localhost:4200

# Las cuatro variables de seed son opcionales como conjunto.
# Si se define una, deben definirse todas.
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
